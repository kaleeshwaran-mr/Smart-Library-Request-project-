background-color: RGB(var(--now-color_background--primary,var(--now-color--neutral-0,255,255,255)));
}

.list-title {
margin: 15px 0;
font-size:16px;
text-align:center;
}

body.-polaris .display_grid_header {
background-color: RGB(var(--now-color_background--primary,var(--now-color--neutral-0,255,255,255)));
color: RGB(var(--now-color_text--primary,221,237,233));
}

.acl-info-message {
