@media only screen and (min-device-width:768px) and (max-device-width:1024px){
.sn-card-component_buttons .sn-widget-button .btn{border-start-end-radius:var(--now-card--border-radius,var(--now-container--border-radius,0));border-start-start-radius:var(--now-card--border-radius,var(--now-container--border-radius,0))}
}
