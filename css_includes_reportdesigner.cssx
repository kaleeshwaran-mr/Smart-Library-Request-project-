.h-card-wrapper_list .h-card.state-selected,.h-card-wrapper_list .h-card.state-selected:hover,.h-card-wrapper_list .h-card:hover{border-color:RGB(var(--now-card--border-color,var(--now-color_border--tertiary,var(--now-color--neutral-3,209,214,214))))}
.h-card-wrapper_list .sn-card-component_accent-bar{border-radius:0}
.form-field .h-card-wrapper{padding:0}
.sn-steam .h-card-wrapper_selectable li>button{padding:var(--now-global-space--lg,14px);text-align:left}
.sn-card-component{color:RGB(var(--now-card-header_heading--primary--color,var(--now-color_text--secondary,var(--now-color--neutral-15,44,53,55))));cursor:default;display:inline-block;float:left;font-size:var(--now-global-font-size--sm, 12px);margin:var(--now-global-space--md,10px) 0 0;position:relative;width:100%}
.rtl .sn-card-component{float:right}
.sn-card-component_first{margin-block-start:0}
.sn-card-component_accent-bar{background-color:RGB(var(--now-card--border-color,var(--now-color_border--tertiary,var(--now-color--neutral-3,209,214,214))));border-end-start-radius:var(--now-card--border-radius,var(--now-container--border-radius,0));border-start-start-radius:var(--now-card--border-radius,var(--now-container--border-radius,0));height:100%;left:0;margin:0;position:absolute;top:0;width:4px}
.sn-card-component_accent-bar_dark{background-color:RGB(var(--now-color_background--primary-actionable,var(--now-color--neutral-18,22,27,28)));opacity:.8}
.sn-card-component_accent-bar_bullet{padding:0 var(--now-global-space--xs,4px)}
#sn_form_inline_stream_container .sn-card-component_accent-bar_bullet{padding:0 var(--now-global-space--sm,6px)}
.sn-card-component_attachment.state-selectable{cursor:pointer}
.sn-card-component_attachment::before{border-start-end-radius:var(--now-card--border-radius,var(--now-container--border-radius,0));border-start-start-radius:var(--now-card--border-radius,var(--now-container--border-radius,0));content:"";height:150%;left:0;overflow:hidden;position:absolute;top:0;width:100%}
.sn-card-component_attachment_vignette::before{display:none}
.sn-card-component_attachment.sn-card-component_attachment_first{border-start-end-radius:var(--now-card--border-radius,var(--now-container--border-radius,0));border-start-start-radius:var(--now-card--border-radius,var(--now-container--border-radius,0));height:135px;margin-block-start:calc(-1 * var(--now-global-space--lg,14px));margin-inline-start:calc(-1 * var(--now-global-space--lg,14px));overflow:hidden;width:calc(100% + (2 * var(--now-global-space--lg,14px)))}
.sn-card-component_attachment.sn-card-component_attachment_first::before{background:radial-gradient(ellipse at center bottom,rgba(0,0,0,0) 0,rgba(0,0,0,.3) 65%,rgba(0,0,0,.4) 85%)}
