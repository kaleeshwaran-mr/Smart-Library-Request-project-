.sn-card-component_form-entry .sn-card-component-form-highlight{border-end-start-radius:var(--now-card--border-radius,var(--now-container--border-radius,0));border-start-start-radius:var(--now-card--border-radius,var(--now-container--border-radius,0));border:1px solid transparent;bottom:1px;left:1px;position:absolute;top:1px;width:5px}
.sn-card-component_form-entry+.sn-card-component_accent-bar+.sn-card-component_buttons,.sn-card-component_form-entry+.sn-card-component_buttons{display:none}
.sn-card-component_headline{color:RGB(var(--now-card-header_heading--primary--color,var(--now-color_text--secondary,var(--now-color--neutral-15,44,53,55))));font-size:var(--now-global-font-size--md, 14px);font-weight:700;padding-block-start:var(--now-global-space--xs,4px);word-break:break-word;word-wrap:break-word}
