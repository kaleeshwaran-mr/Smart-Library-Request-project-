/*! RESOURCE: styles/report_designer.css */
@keyframes passing-through {
0% {
transform: translateY(40px);
opacity: 0;
}
30%,
70% {
transform: translateY(0);
opacity: 1;
}
100% {
transform: translateY(-40px);
opacity: 0;
}
}
@keyframes slide-in {
0% {
transform: translateY(40px);
opacity: 0;
}
30% {
transform: translateY(0);
opacity: 1;
}
}
@keyframes pulse {
0% {
transform: scale(1);
}
10% {
transform: scale(1.1);
}
20% {
transform: scale(1);
}
}
@keyframes modal-data-purge {
0% {
transform: translate(0, 0);
}
50% {
transform: translate(0, calc(-100% + 50px));
}
100% {
transform: translate(0, 0);
}
}
@keyframes side-bar-slide-in {
0% {
visibility: visible;
width: 0;
}
100% {
width: 320px;
}
}
@keyframes side-bar-slide-out {
0% {
width: 320px;
}
100% {
width: 0;
visibility: hidden;
}
}
