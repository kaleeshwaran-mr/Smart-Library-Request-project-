.sn-card-component_attachment.sn-card-attachment-unavailable a{color:RGB(var(--now-color_text--tertiary,var(--now-color--neutral-12,66,80,81)))}
.sn-card-component_attachment .sn-card-component-image-detail{display:inline-block;font-size:var(--now-global-font-size--sm, 12px);margin-block-start:1px;opacity:.8;width:100%}
.sn-card-component_attachment .sn-card-component-image{background-position:0 0;background-repeat:no-repeat;background-size:contain;max-height:350px;max-width:100%;overflow:hidden;width:auto}
.sn-card-component_attachment .sn-card-component-player{height:100%;left:0;overflow:hidden;position:absolute;top:0;width:100%}
.sn-card-component_attachment .sn-card-component-player iframe{width:100%!important}
.sn-card-component_attachment .sn-card-component-play{background-color:RGB(var(--now-color_background--tertiary,var(--now-color--neutral-2,228,230,231)));border-radius:100%;color:RGB(var(--now-color_text--primary,var(--now-color--neutral-18,22,27,28)));font-size:var(--now-global-font-size--xxl, 32px);height:60px;left:50%;line-height:56px;opacity:.8;padding-inline-start:0.8;position:absolute;text-align:center;top:50%;transform:translate(-50%,-50%);width:60px}
.sn-card-component_attachment a{position:relative}
.sn-card-component_buttons{bottom:0;height:0;left:0;margin:0;position:absolute;right:0;transition:height cubic-bezier(.075, .82, .165, 1) .3s;width:100%}
