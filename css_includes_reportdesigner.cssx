.h-card-wrapper_selectable .h-card:hover{background-color:RGB(var(--now-card--background-color--hover,var(--now-card--background-color,var(--now-color_background--primary,var(--now-color--neutral-0,255,255,255)))));border-color:RGB(var(--now-card--border-color--hover,var(--now-color_border--secondary,var(--now-color--neutral-5,172,180,181))))}
.h-card-wrapper_selectable .h-card.state-selected:hover{background-color:RGB(var(--now-card--background-color--active,var(--now-card--background-color,var(--now-color_background--primary,var(--now-color--neutral-0,255,255,255)))));border-color:RGB(var(--now-card--border-color--active,var(--now-color--primary-3,15,67,55)))}
